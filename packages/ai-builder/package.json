{
  "name": "@lumen-orca/ai-builder",
  "version": "1.0.0",
  "description": "AI Builder Platform — Prompt Engineering as Infrastructure",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./safety": {
      "import": "./dist/safety/index.mjs",
      "require": "./dist/safety/index.js",
      "types": "./dist/safety/index.d.ts"
    },
    "./templates": {
      "import": "./dist/templates/index.mjs",
      "require": "./dist/templates/index.js",
      "types": "./dist/templates/index.d.ts"
    },
    "./onboarding": {
      "import": "./dist/onboarding/index.mjs",
      "require": "./dist/onboarding/index.js",
      "types": "./dist/onboarding/index.d.ts"
    },
    "./monetization": {
      "import": "./dist/monetization/index.mjs",
      "require": "./dist/monetization/index.js",
      "types": "./dist/monetization/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "ai",
    "builder",
    "prompt-engineering",
    "llm",
    "infrastructure"
  ],
  "author": "Lumen-Orca Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
