generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  passwordHash     String
  name             String?
  timezone         String               @default("UTC")
  settings         Json?                // { defaultTone, defaultPlatforms, notificationsEnabled, etc. }
  tier             SubscriptionTier     @default(FREE)
  stripeCustomerId String?              @unique
  connections      PlatformConnection[]
  posts            Post[]
  mediaAssets      MediaAsset[]
  creditBalance      CreditBalance?
  subscription       Subscription?
  chatConversations  ChatConversation[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model PlatformConnection {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       Platform
  accessToken    String    // Encrypted at rest (AES-256-GCM)
  refreshToken   String?   // Encrypted at rest
  tokenIv        String    // IV for decryption
  tokenExpiresAt DateTime?
  platformUserId String?
  platformPageId String?   // For Facebook pages, LinkedIn company pages
  platformName   String?   // Display name on that platform
  scopes         String[]
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([tokenExpiresAt])
}

model Post {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  content           String
  platformOverrides Json?           // { "x": "shorter version", "linkedin": "professional version" }
  platforms         Platform[]
  scheduleType      ScheduleType    @default(IMMEDIATE)
  scheduledAt       DateTime?
  timezone          String          @default("UTC")
  status            PostStatus      @default(DRAFT)
  tags              String[]
  aiEnhancement     Json?           // Store AI suggestions and selected tone
  publishResults    PublishResult[]
  mediaAttachments  PostMedia[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([userId, status])
  @@index([scheduledAt])
}

model MediaAsset {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalUrl  String
  originalKey  String      // S3 key
  variants     Json?       // [{ aspectRatio, url, key, width, height }]
  type         MediaType
  mimeType     String
  fileSize     Int
  width        Int?
  height       Int?
  duration     Float?      // Video duration in seconds
  altText      String?
  thumbnailUrl String?
  thumbnailKey String?
  status       MediaStatus @default(UPLOADING)
  posts        PostMedia[]
  createdAt    DateTime    @default(now())

  @@index([userId])
}

model PostMedia {
  id       String     @id @default(cuid())
  postId   String
  post     Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaId  String
  media    MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  position Int        @default(0)

  @@unique([postId, mediaId])
}

model PublishResult {
  id               String        @id @default(cuid())
  postId           String
  post             Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform         Platform
  status           PublishStatus @default(PENDING)
  platformPostId   String?
  platformUrl      String?
  error            String?
  retryCount       Int           @default(0)
  publishedAt      DateTime?
  metrics          Json?         // { impressions, likes, comments, shares, etc. }
  metricsFetchedAt DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([postId, platform])
  @@index([status])
}

model AiEnhancement {
  id               String   @id @default(cuid())
  userId           String
  originalContent  String
  enhancedContent  String
  tone             String
  model            String   @default("claude-sonnet-4-6")
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  createdAt        DateTime @default(now())
}

model CreditBalance {
  id                 String              @id @default(cuid())
  userId             String              @unique
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance            Int                 @default(0) // Credits in cents (100 = $1.00)
  lifetimeUsed       Int                 @default(0) // Total credits ever consumed
  autoTopUpEnabled   Boolean             @default(false) // User consented to auto top-up
  autoTopUpThreshold Int                 @default(100)   // Trigger top-up when balance drops below this
  autoTopUpAmount    Int                 @default(1000)  // Credits to add per auto top-up (1000 = $10)
  updatedAt          DateTime            @updatedAt
  createdAt          DateTime            @default(now())
  transactions       CreditTransaction[]
}

model CreditTransaction {
  id              String         @id @default(cuid())
  creditBalanceId String
  creditBalance   CreditBalance  @relation(fields: [creditBalanceId], references: [id], onDelete: Cascade)
  amount          Int            // Positive = credit added, negative = credit used
  type            CreditTxType
  description     String         // e.g. "Video generation (30s, 3 segments + music)"
  generationType  String?        // e.g. "video", "carousel", "quote-card", "ai-enhance"
  metadata        Json?          // Extra details: { segments: 3, duration: 30, hasMusic: true, ... }
  createdAt       DateTime       @default(now())

  @@index([creditBalanceId, createdAt])
}

enum CreditTxType {
  TOPUP        // Manual or purchased credits
  GENERATION   // Credits consumed by content generation
  REFUND       // Refund for failed generation
  BONUS        // Free credits (signup bonus, promo, etc.)
  AUTO_TOPUP   // Automatic top-up charged via Stripe
  SUBSCRIPTION // Monthly credits included with subscription tier
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  X
  TIKTOK
  YOUTUBE
}

enum PostStatus {
  DRAFT
  QUEUED
  PUBLISHING
  PUBLISHED
  PARTIAL_FAILURE
  FAILED
}

enum PublishStatus {
  PENDING
  PUBLISHING
  SUCCESS
  FAILED
  RETRYING
}

enum ScheduleType {
  IMMEDIATE
  SCHEDULED
  OPTIMAL
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

// ─── Chat ───────────────────────────────────────────────

model ChatConversation {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("New Chat")
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatRole
  content        String
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

enum ChatRole {
  USER
  ASSISTANT
}

// ─── Subscriptions ────────────────────────────────────────

enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
  POWER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeSubscriptionId])
  @@index([userId])
}
